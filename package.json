{
  "name": "magic-fortune-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "resize-images": "node resize-images.mjs",
    "optimize-images": "node optimize-images.mjs",
    "optimize-png": "node optimize-png.mjs --mode=aggressive",
    "optimize-png-moderate": "node optimize-png.mjs --mode=moderate",
    "optimize-png-safe": "node optimize-png.mjs --mode=safe",
    "build:optimized": "npm run resize-images && npm run optimize-images && npm run build",
    "build:webp-only": "npm run build && node remove-png-from-dist.mjs",
    "build:full-optimized": "npm run resize-images && npm run optimize-png && npm run optimize-images && npm run build"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@squoosh/lib": "^0.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "imagemin": "^9.0.1",
    "imagemin-oxipng": "^1.0.0",
    "imagemin-pngquant": "^10.0.0",
    "postcss": "^8.4.47",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10",
    "vite-plugin-imagemin": "^0.6.1"
  }
}
